#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
checkout_root=$(cd -- "$script_dir/.." && pwd)
if [[ -n ${RG_LINUX_RG_ROOT:-} ]]; then
  root=$RG_LINUX_RG_ROOT
elif [[ -d $script_dir/dkms-overlays ]]; then
  root=$script_dir
elif [[ -d $checkout_root/dkms-overlays ]]; then
  root=$checkout_root
else
  root=/usr/share/linux-rg
fi
backup_root=${RG_DKMS_OVERLAY_BACKUP_ROOT:-/tmp/rg-linux-rg-dkms-overlay-backups}
jobs=${RG_DKMS_JOBS:-}
target_kver=${RG_DKMS_KVER:-}
patch_only=0
if_present=0

usage() {
  cat <<'USAGE'
usage: rgx1gen11-dkms-overlay-apply [options] [kernel-release]

Apply linux-rg compatibility patches to known DKMS source trees.

Options:
  --patch-only    Patch DKMS sources and leave rebuilds to the pacman DKMS hook
  --if-present    Skip missing optional DKMS sources or linux-rg headers
  --jobs N        DKMS rebuild jobs, defaulting to 80% of local CPUs
USAGE
}

while (($#)); do
  case "$1" in
    --patch-only)
      patch_only=1
      shift
      ;;
    --if-present)
      if_present=1
      shift
      ;;
    --jobs)
      [[ $# -ge 2 ]] || {
        printf 'error: --jobs needs a value\n' >&2
        exit 2
      }
      jobs=$2
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --*)
      printf 'error: unknown option: %s\n' "$1" >&2
      exit 2
      ;;
    *)
      [[ -z $target_kver ]] || {
        printf 'error: multiple kernel releases specified\n' >&2
        exit 2
      }
      target_kver=$1
      shift
      ;;
  esac
done

if ((EUID != 0)); then
  printf 'error: run as root\n' >&2
  exit 1
fi

if [[ -z $jobs ]]; then
  jobs=$(nproc)
  jobs=$((jobs * 80 / 100))
  (( jobs >= 1 )) || jobs=1
fi

if [[ -z $target_kver ]]; then
  target_kver=$(
    find /usr/lib/modules -maxdepth 2 -type d -path '*/build' -printf '%h\n' |
      sed 's|.*/||' |
      grep -- '-rg$' |
      sort -V |
      tail -n 1
  )
fi

if [[ -z $target_kver ]]; then
  if ((if_present)); then
    printf 'skip: no installed linux-rg module tree\n'
    exit 0
  fi
  printf 'error: could not find an installed linux-rg module tree\n' >&2
  exit 1
fi

if [[ ! -d /usr/lib/modules/$target_kver/build ]]; then
  if ((if_present)); then
    printf 'skip: missing headers for %s\n' "$target_kver"
    exit 0
  fi
  printf 'error: missing headers for %s\n' "$target_kver" >&2
  exit 1
fi

apply_patch_file() {
  local dir=$1
  local patch_file=$2

  if patch -d "$dir" -p2 --dry-run --forward --silent < "$patch_file"; then
    patch -d "$dir" -p2 --forward < "$patch_file"
    return 0
  fi

  if patch -d "$dir" -p2 --dry-run --reverse --silent < "$patch_file"; then
    printf 'already patched: %s\n' "$dir"
    return 0
  fi

  printf 'error: patch does not apply cleanly: %s -> %s\n' "$patch_file" "$dir" >&2
  return 1
}

backup_source() {
  local src_name=$1
  local src_dir=/usr/src/$src_name
  local stamp=$2

  mkdir -p "$backup_root/$stamp"
  cp -a "$src_dir" "$backup_root/$stamp/$src_name"
  printf 'backup: %s\n' "$backup_root/$stamp/$src_name"
}

patch_module() {
  local module=$1
  local version=$2
  local src_name=$3
  local patch_rel=$4
  local src_dir=/usr/src/$src_name
  local patch_file=$root/$patch_rel
  local stamp=$5

  printf '\n== patch %s/%s ==\n' "$module" "$version"

  [[ -f $patch_file ]] || {
    printf 'error: missing patch file: %s\n' "$patch_file" >&2
    return 1
  }
  [[ -d $src_dir ]] || {
    if ((if_present)); then
      printf 'skip: missing DKMS source: %s\n' "$src_dir"
      return 0
    fi
    printf 'error: missing DKMS source: %s\n' "$src_dir" >&2
    return 1
  }

  backup_source "$src_name" "$stamp"
  apply_patch_file "$src_dir" "$patch_file"

  local build_dir=/var/lib/dkms/$module/$version/build
  if [[ -d $build_dir && ! $build_dir -ef $src_dir ]]; then
    apply_patch_file "$build_dir" "$patch_file"
  fi
}

skip_duplicate_v4l2loopback() {
  local module=v4l2loopback
  local version=0.15.3
  local src_name=v4l2loopback-0.15.3
  local src_dir=/usr/src/$src_name
  local stamp=$1
  local marker='linux-rg ships v4l2loopback in-tree'

  printf '\n== skip %s/%s for %s ==\n' "$module" "$version" "$target_kver"

  [[ -d $src_dir ]] || {
    if ((if_present)); then
      printf 'skip: missing DKMS source: %s\n' "$src_dir"
      return 0
    fi
    printf 'error: missing DKMS source: %s\n' "$src_dir" >&2
    return 1
  }

  backup_source "$src_name" "$stamp"
  for dkms_conf in "$src_dir/dkms.conf" "/var/lib/dkms/$module/$version/build/dkms.conf"; do
    [[ -f $dkms_conf ]] || continue
    if rg -q --fixed-strings "$marker" "$dkms_conf"; then
      printf 'already patched: %s\n' "$dkms_conf"
      continue
    fi
    cat >>"$dkms_conf" <<'EOF'

# linux-rg ships v4l2loopback in-tree; keep this DKMS package for fallback kernels.
case "${kernelver:-}" in
  *-rg) BUILD_EXCLUSIVE_KERNEL="linux-rg ships v4l2loopback in-tree" ;;
esac
EOF
    printf 'patched: %s\n' "$dkms_conf"
  done
}

rebuild_module() {
  local module=$1
  local version=$2

  printf '\n== rebuild %s/%s for %s ==\n' "$module" "$version" "$target_kver"
  MAKEFLAGS=-j"$jobs" dkms build -m "$module" -v "$version" -k "$target_kver"
  MAKEFLAGS=-j"$jobs" dkms install -m "$module" -v "$version" -k "$target_kver"
}

stamp=$(date +%Y%m%d-%H%M%S)

printf 'target kernel: %s\n' "$target_kver"
printf 'jobs: %s\n' "$jobs"

patch_module ddcci 0.4.5 ddcci-0.4.5 dkms-overlays/ddcci-0.4.5-linux-7.0.patch "$stamp"
patch_module rtl88xxau r1298.b44d288 rtl88xxau-r1298.b44d288 dkms-overlays/rtl88xxau-r1298-linux-7.0.patch "$stamp"
patch_module evdi 1.14.7 evdi-1.14.7 dkms-overlays/evdi-1.14.7-linux-7.0.patch "$stamp"
skip_duplicate_v4l2loopback "$stamp"

if ((patch_only)); then
  printf '\npatch-only: dkms rebuild left to pacman hook\n'
  exit 0
fi

rebuild_module ddcci 0.4.5
rebuild_module rtl88xxau r1298.b44d288
rebuild_module evdi 1.14.7

depmod "$target_kver"

printf '\n== dkms status ==\n'
dkms status
