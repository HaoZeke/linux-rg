+static void prepare_workingset_protection(pg_data_t *pgdat,
+					  struct scan_control *sc)
+{
+	unsigned long anon_min_pages;
+	unsigned long clean_low_pages;
+	unsigned long clean_min_pages;
+	unsigned long node_mem_total;
+	struct sysinfo i;
+
+	sc->anon_below_min = 0;
+	sc->clean_below_low = 0;
+	sc->clean_below_min = 0;
+
+	if (!sysctl_workingset_protection)
+		return;
+
+	if (!sysctl_anon_min_ratio &&
+	    !sysctl_clean_low_ratio &&
+	    !sysctl_clean_min_ratio)
+		return;
+
+#ifdef CONFIG_NUMA
+	si_meminfo_node(&i, pgdat->node_id);
+#else
+	si_meminfo(&i);
+#endif
+	node_mem_total = i.totalram;
+	anon_min_pages = node_mem_total * sysctl_anon_min_ratio / 100;
+	clean_low_pages = node_mem_total * sysctl_clean_low_ratio / 100;
+	clean_min_pages = node_mem_total * sysctl_clean_min_ratio / 100;
+
+	if (sysctl_anon_min_ratio) {
+		unsigned long reclaimable_anon;
+
+		reclaimable_anon =
+			node_page_state(pgdat, NR_ACTIVE_ANON) +
+			node_page_state(pgdat, NR_INACTIVE_ANON) +
+			node_page_state(pgdat, NR_ISOLATED_ANON);
+
+		sc->anon_below_min = reclaimable_anon < anon_min_pages;
+	}
+
+	if (sysctl_clean_low_ratio || sysctl_clean_min_ratio) {
+		unsigned long clean;
+		unsigned long dirty;
+		unsigned long reclaimable_file;
+
+		reclaimable_file =
+			node_page_state(pgdat, NR_ACTIVE_FILE) +
+			node_page_state(pgdat, NR_INACTIVE_FILE) +
+			node_page_state(pgdat, NR_ISOLATED_FILE);
+		dirty = node_page_state(pgdat, NR_FILE_DIRTY);
+		clean = reclaimable_file > dirty ? reclaimable_file - dirty : 0;
+
+		sc->clean_below_low = clean < clean_low_pages;
+		sc->clean_below_min = clean < clean_min_pages;
+	}
+}
+
