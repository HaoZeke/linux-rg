#!/usr/bin/env bash
set -euo pipefail

repo=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
script="$repo/scripts/rgx1gen11-reinstall-check-root"

fail() {
  printf 'fail: %s\n' "$1" >&2
  exit 1
}

test -x "$script" || fail "missing script: $script"
bash -n "$script"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

make_pkg() {
  local pkg=$1
  local include_live=${2:-1}
  local root=$tmpdir/root
  rm -rf "$root"
  mkdir -p \
    "$root/usr/bin" \
    "$root/usr/lib/modules/9.9.9-rg/kernel/crypto/async_tx" \
    "$root/usr/lib/modules/9.9.9-rg/kernel/crypto" \
    "$root/usr/lib/modules/9.9.9-rg/kernel/drivers/md" \
    "$root/usr/lib/systemd/system" \
    "$root/usr/share/libalpm/hooks" \
    "$root/usr/share/linux-rg/dkms-overlays"
  : > "$root/usr/bin/rgx1gen11-boot-check"
  if (( include_live )); then
    : > "$root/usr/bin/rgx1gen11-live-check"
  fi
  : > "$root/usr/bin/rgx1gen11-dkms-overlay-apply"
  : > "$root/usr/lib/modules/9.9.9-rg/vmlinuz"
  : > "$root/usr/lib/modules/9.9.9-rg/kernel/crypto/async_tx/async_tx.ko.zst"
  : > "$root/usr/lib/modules/9.9.9-rg/kernel/crypto/async_tx/async_xor.ko.zst"
  : > "$root/usr/lib/modules/9.9.9-rg/kernel/crypto/lz4.ko.zst"
  : > "$root/usr/lib/modules/9.9.9-rg/kernel/crypto/lz4hc.ko.zst"
  : > "$root/usr/lib/modules/9.9.9-rg/kernel/drivers/md/dm-bufio.ko.zst"
  : > "$root/usr/lib/modules/9.9.9-rg/kernel/drivers/md/dm-integrity.ko.zst"
  : > "$root/usr/lib/systemd/system/rgx1gen11-hibernate-image-size.service"
  : > "$root/usr/share/libalpm/hooks/69-linux-rg-dkms-overlays.hook"
  : > "$root/usr/share/linux-rg/dkms-overlays/ddcci-0.4.5-linux-7.0.patch"
  : > "$root/usr/share/linux-rg/dkms-overlays/evdi-1.14.7-linux-7.0.patch"
  : > "$root/usr/share/linux-rg/dkms-overlays/rtl88xxau-r1298-linux-7.0.patch"
  bsdtar --zstd -cf "$pkg" -C "$root" usr
}

make_pkg "$tmpdir/linux-rg-7.0.12.arch1-1-x86_64.pkg.tar.zst"
make_pkg "$tmpdir/linux-rg-headers-7.0.12.arch1-1-x86_64.pkg.tar.zst"

bad_dir="$tmpdir/bad"
mkdir -p "$bad_dir"
make_pkg "$bad_dir/linux-rg-7.0.12.arch1-1-x86_64.pkg.tar.zst" 0
make_pkg "$bad_dir/linux-rg-headers-7.0.12.arch1-1-x86_64.pkg.tar.zst"
bad_out="$tmpdir/bad-out"
if "$script" --dry-run --artifact-dir "$bad_dir" >"$bad_out" 2>&1; then
  fail "dry-run should reject package missing live-check"
fi
rg -Fq 'package payload missing: usr/bin/rgx1gen11-live-check' "$bad_out" \
  || fail "dry-run should name missing live-check payload"

out="$tmpdir/out"
"$script" --dry-run --artifact-dir "$tmpdir" >"$out"

rg -Fq 'ok: linux-rg package payload includes live checks, DKMS overlays, and initramfs modules' "$out" \
  || fail "dry-run should validate package payload"
rg -Fq 'dry-run: pacman -U' "$out" \
  || fail "dry-run should print pacman reinstall command"
rg -Fq 'dry-run: mkinitcpio -p linux-rg' "$out" \
  || fail "dry-run should print mkinitcpio command"
rg -Fq 'dry-run: rgx1gen11-boot-check --installed' "$out" \
  || fail "dry-run should print installed boot check command"

rg -Fq 'trash-put' "$script" \
  || fail "boot cleanup should use trash-put"
! rg -Fq -- '-delete' "$script" \
  || fail "boot cleanup should not hard-delete files"

printf 'ok\n'
