#!/usr/bin/env bash
set -euo pipefail

root=${RG_LINUX_RG_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}
backup_root=${RG_DKMS_OVERLAY_BACKUP_ROOT:-/tmp/rg-linux-rg-dkms-overlay-backups}
jobs=${RG_DKMS_JOBS:-}
target_kver=${1:-${RG_DKMS_KVER:-}}

if (( EUID != 0 )); then
  printf 'error: run as root\n' >&2
  exit 1
fi

if [[ -z $jobs ]]; then
  jobs=$(nproc)
  jobs=$((jobs * 80 / 100))
  (( jobs >= 1 )) || jobs=1
fi

if [[ -z $target_kver ]]; then
  target_kver=$(
    find /usr/lib/modules -maxdepth 2 -type d -path '*/build' -printf '%h\n' |
      sed 's|.*/||' |
      rg -- '-rg$' |
      sort -V |
      tail -n 1
  )
fi

if [[ -z $target_kver ]]; then
  printf 'error: could not find an installed linux-rg module tree\n' >&2
  exit 1
fi

if [[ ! -d /usr/lib/modules/$target_kver/build ]]; then
  printf 'error: missing headers for %s\n' "$target_kver" >&2
  exit 1
fi

apply_patch_file() {
  local dir=$1
  local patch_file=$2

  if patch -d "$dir" -p2 --dry-run --forward --silent < "$patch_file"; then
    patch -d "$dir" -p2 --forward < "$patch_file"
    return 0
  fi

  if patch -d "$dir" -p2 --dry-run --reverse --silent < "$patch_file"; then
    printf 'already patched: %s\n' "$dir"
    return 0
  fi

  printf 'error: patch does not apply cleanly: %s -> %s\n' "$patch_file" "$dir" >&2
  return 1
}

backup_source() {
  local src_name=$1
  local src_dir=/usr/src/$src_name
  local stamp=$2

  mkdir -p "$backup_root/$stamp"
  cp -a "$src_dir" "$backup_root/$stamp/$src_name"
  printf 'backup: %s\n' "$backup_root/$stamp/$src_name"
}

patch_module() {
  local module=$1
  local version=$2
  local src_name=$3
  local patch_rel=$4
  local src_dir=/usr/src/$src_name
  local patch_file=$root/$patch_rel
  local stamp=$5

  printf '\n== patch %s/%s ==\n' "$module" "$version"

  [[ -f $patch_file ]] || {
    printf 'error: missing patch file: %s\n' "$patch_file" >&2
    return 1
  }
  [[ -d $src_dir ]] || {
    printf 'error: missing DKMS source: %s\n' "$src_dir" >&2
    return 1
  }

  backup_source "$src_name" "$stamp"
  apply_patch_file "$src_dir" "$patch_file"

  local build_dir=/var/lib/dkms/$module/$version/build
  if [[ -d $build_dir && ! $build_dir -ef $src_dir ]]; then
    apply_patch_file "$build_dir" "$patch_file"
  fi
}

rebuild_module() {
  local module=$1
  local version=$2

  printf '\n== rebuild %s/%s for %s ==\n' "$module" "$version" "$target_kver"
  MAKEFLAGS=-j"$jobs" dkms build -m "$module" -v "$version" -k "$target_kver"
  MAKEFLAGS=-j"$jobs" dkms install -m "$module" -v "$version" -k "$target_kver"
}

stamp=$(date +%Y%m%d-%H%M%S)

printf 'target kernel: %s\n' "$target_kver"
printf 'jobs: %s\n' "$jobs"

patch_module ddcci 0.4.5 ddcci-0.4.5 dkms-overlays/ddcci-0.4.5-linux-7.0.patch "$stamp"
patch_module rtl88xxau r1298.b44d288 rtl88xxau-r1298.b44d288 dkms-overlays/rtl88xxau-r1298-linux-7.0.patch "$stamp"
patch_module evdi 1.14.7 evdi-1.14.7 dkms-overlays/evdi-1.14.7-linux-7.0.patch "$stamp"

rebuild_module ddcci 0.4.5
rebuild_module rtl88xxau r1298.b44d288
rebuild_module evdi 1.14.7

depmod "$target_kver"

printf '\n== dkms status ==\n'
dkms status
