#!/usr/bin/env bash
set -euo pipefail

dry_run=0
clean_boot=1
artifact_dir=${LINUX_RG_ARTIFACT_DIR:-}
kernel_pkg=${LINUX_RG_KERNEL_PKG:-}
headers_pkg=${LINUX_RG_HEADERS_PKG:-}
refind_conf=${REFIND_CONF:-/boot/EFI/refind/refind.conf}
refind_icon=${REFIND_ICON:-/EFI/refind/icons/os_linux_rg.png}
refind_icon_target=${REFIND_ICON_TARGET:-/boot${refind_icon}}
stamp=$(date +%Y%m%d-%H%M%S)

usage() {
  cat <<'USAGE'
usage: rgx1gen11-reinstall-check-root [options]

Reinstall linux-rg packages, rebuild the linux-rg initramfs, and print boot and
ownership checks. This is for repairing an installed tree from preserved
packages without rebuilding the kernel.

Options:
  --dry-run             Validate package discovery and payload without writes
  --artifact-dir PATH   Directory containing linux-rg package artifacts
  --kernel-pkg PATH     Exact linux-rg package artifact
  --headers-pkg PATH    Exact linux-rg-headers package artifact
  --skip-boot-clean     Do not trash rEFInd screenshots or FSCK*.REC files
  -h, --help            Show this help
USAGE
}

while (($#)); do
  case "$1" in
    --dry-run)
      dry_run=1
      shift
      ;;
    --artifact-dir)
      artifact_dir=$2
      shift 2
      ;;
    --kernel-pkg)
      kernel_pkg=$2
      shift 2
      ;;
    --headers-pkg)
      headers_pkg=$2
      shift 2
      ;;
    --skip-boot-clean)
      clean_boot=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

require_root() {
  if ((dry_run)); then
    return
  fi
  if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
    printf 'error: run as root or pass --dry-run\n' >&2
    exit 1
  fi
}

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
checkout_root=$(cd -- "$script_dir/.." && pwd)

default_refind_icon_source() {
  if [[ -f /usr/share/linux-rg/refind/os_linux_rg.png ]]; then
    printf '%s\n' /usr/share/linux-rg/refind/os_linux_rg.png
  elif [[ -f $checkout_root/os_linux_rg.png ]]; then
    printf '%s\n' "$checkout_root/os_linux_rg.png"
  else
    printf '%s\n' /usr/share/linux-rg/refind/os_linux_rg.png
  fi
}

refind_icon_source=${REFIND_ICON_SOURCE:-$(default_refind_icon_source)}

default_artifact_home() {
  local home user
  user=${SUDO_USER:-}
  if [[ -n $user && $user != root ]] && command -v getent >/dev/null 2>&1; then
    home=$(getent passwd "$user" | cut -d: -f6 || true)
    if [[ -n $home ]]; then
      printf '%s\n' "$home"
      return
    fi
  fi
  printf '%s\n' "${HOME:-/root}"
}

default_artifact_dir() {
  if compgen -G "$checkout_root/linux-rg-[0-9]*-x86_64.pkg.tar.zst" >/dev/null; then
    printf '%s\n' "$checkout_root"
    return
  fi
  printf '%s/.local/share/rg-kernel/artifacts/linux-rg\n' "$(default_artifact_home)"
}

latest_package() {
  local dir=$1 pattern=$2 description=$3
  local candidates=() sorted=()
  if [[ -d $dir ]]; then
    mapfile -d '' -t candidates < <(find "$dir" -maxdepth 1 -type f -name "$pattern" -print0)
  fi
  if (( ${#candidates[@]} == 0 )); then
    printf 'error: no %s found under %s\n' "$description" "$dir" >&2
    exit 1
  fi
  mapfile -d '' -t sorted < <(printf '%s\0' "${candidates[@]}" | sort -z)
  printf '%s\n' "${sorted[-1]}"
}

package_has_path() {
  local pkg=$1 path=$2
  bsdtar -tf "$pkg" | rg -qx "$path"
}

png_color_type() {
  local path=$1
  od -An -tu1 -j25 -N1 "$path" 2>/dev/null | tr -d '[:space:]'
}

png_corner_alpha() {
  local path=$1
  python - "$path" 2>/dev/null <<'PY' || true
import struct
import sys
import zlib

path = sys.argv[1]
with open(path, "rb") as handle:
    data = handle.read()

if data[:8] != b"\x89PNG\r\n\x1a\n":
    raise SystemExit(1)

pos = 8
width = bit_depth = color_type = interlace = None
idat = []
while pos + 8 <= len(data):
    length = struct.unpack(">I", data[pos : pos + 4])[0]
    kind = data[pos + 4 : pos + 8]
    chunk = data[pos + 8 : pos + 8 + length]
    pos += length + 12
    if kind == b"IHDR":
        width, _height, bit_depth, color_type, _compression, _filter, interlace = struct.unpack(
            ">IIBBBBB", chunk
        )
    elif kind == b"IDAT":
        idat.append(chunk)
    elif kind == b"IEND":
        break

if bit_depth != 8 or color_type not in (4, 6) or interlace != 0 or not idat:
    raise SystemExit(1)

raw = zlib.decompress(b"".join(idat))
channels = {4: 2, 6: 4}[color_type]
first_row = raw[: 1 + (width * channels)]
if len(first_row) < 1 + channels:
    raise SystemExit(1)

print(first_row[channels])
PY
}

package_png_color_type() {
  local pkg=$1 path=$2
  local tmp
  tmp=$(mktemp)
  if ! bsdtar -xOf "$pkg" "$path" >"$tmp" 2>/dev/null; then
    rm -f "$tmp"
    return 1
  fi
  png_color_type "$tmp"
  rm -f "$tmp"
}

package_png_corner_alpha() {
  local pkg=$1 path=$2
  local tmp
  tmp=$(mktemp)
  if ! bsdtar -xOf "$pkg" "$path" >"$tmp" 2>/dev/null; then
    rm -f "$tmp"
    return 1
  fi
  png_corner_alpha "$tmp"
  rm -f "$tmp"
}

want_png_alpha_color_type() {
  local color_type=$1 description=$2
  case "$color_type" in
    4|6)
      return 0
      ;;
    "")
      printf 'error: %s PNG color type unreadable\n' "$description" >&2
      exit 1
      ;;
    *)
      printf 'error: %s lacks PNG alpha channel (color type %s)\n' "$description" "$color_type" >&2
      exit 1
      ;;
  esac
}

want_png_transparent_corner() {
  local alpha=$1 description=$2 path=$3
  case "$alpha" in
    0)
      return 0
      ;;
    "")
      printf 'error: %s corner alpha unreadable: %s\n' "$description" "$path" >&2
      exit 1
      ;;
    *)
      printf 'error: %s corner is not transparent: %s (alpha %s)\n' "$description" "$path" "$alpha" >&2
      exit 1
      ;;
  esac
}

backup_file() {
  local path=$1
  if [[ -e $path ]]; then
    local backup="${path}.rg-linux-rg-${stamp}.bak"
    cp -a "$path" "$backup"
    printf 'backup: %s\n' "$backup"
  fi
}

package_kver() {
  bsdtar -tf "$kernel_pkg" |
    sed -n 's#^usr/lib/modules/\([^/]*-rg\)/vmlinuz$#\1#p' |
    head -n 1
}

validate_package_payload() {
  local kver path icon_path icon_color_type
  kver=$(package_kver)
  if [[ -z $kver ]]; then
    printf 'error: could not read linux-rg kernel version from %s\n' "$kernel_pkg" >&2
    exit 1
  fi
  for path in \
    usr/bin/rgx1gen11-boot-check \
    usr/bin/rgx1gen11-live-check \
    usr/bin/rgx1gen11-dkms-overlay-apply \
    usr/bin/linux-rg-module-symvers \
    usr/share/linux-rg/refind/os_linux_rg.png \
    "usr/lib/modules/$kver/kernel/crypto/async_tx/async_tx.ko.zst" \
    "usr/lib/modules/$kver/kernel/crypto/async_tx/async_xor.ko.zst" \
    "usr/lib/modules/$kver/kernel/crypto/lz4.ko.zst" \
    "usr/lib/modules/$kver/kernel/crypto/lz4hc.ko.zst" \
    "usr/lib/modules/$kver/kernel/drivers/md/dm-bufio.ko.zst" \
    "usr/lib/modules/$kver/kernel/drivers/md/dm-integrity.ko.zst" \
    usr/lib/systemd/system/rgx1gen11-hibernate-image-size.service \
    usr/share/libalpm/hooks/69-linux-rg-dkms-overlays.hook \
    usr/share/linux-rg/dkms-overlays/ddcci-0.4.5-linux-7.0.patch \
    usr/share/linux-rg/dkms-overlays/evdi-1.14.7-linux-7.0.patch \
    usr/share/linux-rg/dkms-overlays/rtl88xxau-r1298-linux-7.0.patch; do
    if ! package_has_path "$kernel_pkg" "$path"; then
      printf 'error: package payload missing: %s\n' "$path" >&2
      exit 1
    fi
  done
  icon_path=usr/share/linux-rg/refind/os_linux_rg.png
  icon_color_type=$(package_png_color_type "$kernel_pkg" "$icon_path")
  case "$icon_color_type" in
    4|6) ;;
    "")
      printf 'error: package rEFInd icon PNG color type unreadable: %s\n' "$icon_path" >&2
      exit 1
      ;;
    *)
      printf 'error: package rEFInd icon lacks PNG alpha channel: %s (color type %s)\n' "$icon_path" "$icon_color_type" >&2
      exit 1
      ;;
  esac
  want_png_transparent_corner "$(package_png_corner_alpha "$kernel_pkg" "$icon_path")" \
    "package rEFInd icon" "$icon_path"
  printf 'ok: linux-rg package payload includes live checks, DKMS overlays, and initramfs modules\n'
}

install_refind_icon() {
  if [[ ! -f $refind_icon_source ]]; then
    printf 'error: missing rEFInd icon source: %s\n' "$refind_icon_source" >&2
    exit 1
  fi
  want_png_alpha_color_type "$(png_color_type "$refind_icon_source")" "rEFInd icon source $refind_icon_source"
  want_png_transparent_corner "$(png_corner_alpha "$refind_icon_source")" \
    "rEFInd icon source" "$refind_icon_source"
  install -Dm644 "$refind_icon_source" "$refind_icon_target"
  want_png_alpha_color_type "$(png_color_type "$refind_icon_target")" "rEFInd icon target $refind_icon_target"
  want_png_transparent_corner "$(png_corner_alpha "$refind_icon_target")" \
    "rEFInd icon target" "$refind_icon_target"
  printf 'wrote: %s\n' "$refind_icon_target"
}

write_refind_icon_line() {
  local tmp
  if [[ ! -r $refind_conf ]]; then
    printf 'error: rEFInd config is not readable: %s\n' "$refind_conf" >&2
    exit 1
  fi
  tmp=$(mktemp)
  awk -v icon_line="    icon     $refind_icon" '
    /^menuentry "Arch Linux linux-rg" \{/ {
      in_linux_rg = 1
      icon_written = 0
      print
      next
    }
    in_linux_rg && /^[[:space:]]*icon[[:space:]]+/ {
      if (!icon_written) {
        print icon_line
        icon_written = 1
      }
      next
    }
    in_linux_rg && /^[[:space:]]*loader[[:space:]]+/ && !icon_written {
      print icon_line
      icon_written = 1
    }
    in_linux_rg && /^}/ {
      in_linux_rg = 0
      icon_written = 0
    }
    { print }
  ' "$refind_conf" > "$tmp"
  if ! cmp -s "$tmp" "$refind_conf"; then
    backup_file "$refind_conf"
    install -m 0644 "$tmp" "$refind_conf"
    printf 'wrote: %s\n' "$refind_conf"
  else
    printf 'unchanged: %s\n' "$refind_conf"
  fi
  rm -f "$tmp"
}

show_owner_sample() {
  local kver=$1
  bsdtar -tvf "$kernel_pkg" \
    usr/bin/rgx1gen11-boot-check \
    usr/share/libalpm/hooks/69-linux-rg-dkms-overlays.hook \
    "usr/lib/modules/$kver/vmlinuz"
}

boot_junk_paths() {
  find /boot -maxdepth 1 \
    \( -name 'screenshot_*.bmp' -o -name 'FSCK*.REC' \) \
    -type f -print
}

clean_boot_junk() {
  local paths=()
  if (( ! clean_boot )); then
    printf 'skip: boot cleanup disabled\n'
    return
  fi
  mapfile -t paths < <(boot_junk_paths || true)
  if (( ${#paths[@]} == 0 )); then
    printf 'ok: no known rEFInd/FSCK junk under /boot\n'
    return
  fi
  if (( dry_run )); then
    printf 'dry-run: would trash known rEFInd/FSCK junk under /boot:\n'
    printf '%s\n' "${paths[@]}"
    return
  fi
  if ! command -v trash-put >/dev/null 2>&1; then
    printf 'error: trash-put is required for /boot cleanup\n' >&2
    exit 1
  fi
  trash-put -- "${paths[@]}"
}

repair_package_ownership() {
  pacman -Qlq linux-rg linux-rg-headers |
    sort -u |
    while IFS= read -r path; do
      [[ -e $path || -L $path ]] && chown -h root:root "$path"
    done
}

repair_dkms_overlays() {
  local kver=$1
  local jobs=${RG_DKMS_JOBS:-9}

  if ! command -v rgx1gen11-dkms-overlay-apply >/dev/null 2>&1; then
    printf 'error: rgx1gen11-dkms-overlay-apply missing after package install\n' >&2
    return 1
  fi
  if ! command -v linux-rg-module-symvers >/dev/null 2>&1; then
    printf 'error: linux-rg-module-symvers missing after package install\n' >&2
    return 1
  fi
  RG_DKMS_JOBS=$jobs rgx1gen11-dkms-overlay-apply "$kver"
}

run_package_check() {
  local output=/tmp/rg-linux-rg-qkk-after-reinstall.out
  pacman -Qkk linux-rg linux-rg-headers 2>&1 | tee "$output" | tail -n 120
  if rg -q 'UID mismatch|GID mismatch|altered files' "$output"; then
    printf 'error: pacman ownership check still reports altered files\n' >&2
    return 1
  fi
}

require_root

if [[ -z $artifact_dir ]]; then
  artifact_dir=$(default_artifact_dir)
fi
if [[ -z $kernel_pkg ]]; then
  kernel_pkg=$(latest_package "$artifact_dir" 'linux-rg-[0-9]*-x86_64.pkg.tar.zst' 'linux-rg package')
fi
if [[ -z $headers_pkg ]]; then
  headers_pkg=$(latest_package "$artifact_dir" 'linux-rg-headers-[0-9]*-x86_64.pkg.tar.zst' 'linux-rg-headers package')
fi

printf '== preflight ==\n'
df -h / /boot || true
stat -c '%U:%G %a %s %n' "$kernel_pkg" "$headers_pkg"
validate_package_payload
kver=$(package_kver)
if [[ -z $kver ]]; then
  printf 'error: could not read linux-rg kernel version from %s\n' "$kernel_pkg" >&2
  exit 1
fi

printf '\n== package owner metadata sample ==\n'
show_owner_sample "$kver"

printf '\n== boot junk cleanup ==\n'
clean_boot_junk
df -h /boot || true

if (( dry_run )); then
  printf '\n== dry-run package commands ==\n'
  printf 'dry-run: pacman --noconfirm -U %q %q\n' "$kernel_pkg" "$headers_pkg"
  printf 'dry-run: RG_DKMS_JOBS=%q rgx1gen11-dkms-overlay-apply %q\n' "${RG_DKMS_JOBS:-9}" "$kver"
  printf 'dry-run: mkinitcpio -p linux-rg\n'
  printf 'dry-run: install %q %q\n' "$refind_icon_source" "$refind_icon_target"
  printf 'dry-run: rgx1gen11-boot-check --installed\n'
  exit 0
fi

printf '\n== reinstall linux-rg packages ==\n'
pacman --noconfirm -U "$kernel_pkg" "$headers_pkg"
repair_package_ownership

printf '\n== repair dkms overlays ==\n'
repair_dkms_overlays "$kver"

printf '\n== rebuild initramfs ==\n'
mkinitcpio -p linux-rg
if [[ -e /boot/vmlinuz-linux-rg ]]; then
  chown root:root /boot/vmlinuz-linux-rg
  chmod 0644 /boot/vmlinuz-linux-rg
fi
if [[ -e /boot/initramfs-linux-rg.img ]]; then
  chown root:root /boot/initramfs-linux-rg.img
  chmod 0644 /boot/initramfs-linux-rg.img
fi

printf '\n== rEFInd icon ==\n'
install_refind_icon
write_refind_icon_line

printf '\n== boot check ==\n'
rgx1gen11-boot-check --installed

printf '\n== package ownership check ==\n'
run_package_check

printf '\n== critical ownership sample ==\n'
stat -c '%U:%G %a %n' \
  /usr/bin/rgx1gen11-boot-check \
  "/usr/lib/modules/$kver/vmlinuz" \
  /boot/vmlinuz-linux-rg \
  /boot/initramfs-linux-rg.img

printf '\n== rEFInd linux-rg entry ==\n'
sed -n '/^menuentry "Arch Linux linux-rg" {/,/^}/p' "$refind_conf" || true

printf '\n== final space ==\n'
df -h / /boot
