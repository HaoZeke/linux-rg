#!/usr/bin/env bash
set -euo pipefail

default_artifact_home() {
  local home user
  if [[ -n ${LINUX_RG_ARTIFACT_HOME:-} ]]; then
    printf '%s\n' "$LINUX_RG_ARTIFACT_HOME"
    return
  fi

  user=${SUDO_USER:-}
  if [[ -n $user && $user != root ]] && command -v getent >/dev/null 2>&1; then
    home=$(getent passwd "$user" | cut -d: -f6 || true)
    if [[ -n $home ]]; then
      printf '%s\n' "$home"
      return
    fi
  fi

  if [[ -n ${HOME:-} ]]; then
    printf '%s\n' "$HOME"
  else
    printf '/root\n'
  fi
}

default_artifact_dir() {
  printf '%s/.local/share/rg-kernel/artifacts/linux-rg\n' "$(default_artifact_home)"
}

latest_package() {
  local dir=$1 pattern=$2 description=$3
  local candidates=() sorted=()
  if [[ -d $dir ]]; then
    mapfile -d '' -t candidates < <(find "$dir" -maxdepth 1 -type f -name "$pattern" -print0)
  fi
  if (( ${#candidates[@]} == 0 )); then
    printf 'error: no %s found under %s\n' "$description" "$dir" >&2
    return 1
  fi
  mapfile -d '' -t sorted < <(printf '%s\0' "${candidates[@]}" | sort -z)
  printf '%s\n' "${sorted[-1]}"
}

artifact_dir=${LINUX_RG_ARTIFACT_DIR:-$(default_artifact_dir)}
kernel_pkg=${LINUX_RG_KERNEL_PKG:-$(latest_package "$artifact_dir" 'linux-rg-[0-9]*-x86_64.pkg.tar.zst' 'linux-rg package')}
headers_pkg=${LINUX_RG_HEADERS_PKG:-$(latest_package "$artifact_dir" 'linux-rg-headers-[0-9]*-x86_64.pkg.tar.zst' 'linux-rg-headers package')}
refind_conf=${REFIND_CONF:-/boot/EFI/refind/refind.conf}
mkinitcpio_base=${MKINITCPIO_BASE:-/etc/mkinitcpio.conf}
mkinitcpio_config=${MKINITCPIO_CONFIG:-/etc/mkinitcpio-linux-rg.conf}
mkinitcpio_preset=${MKINITCPIO_PRESET:-/etc/mkinitcpio.d/linux-rg.preset}
boot_kernel=${BOOT_KERNEL:-/boot/vmlinuz-linux-rg}
boot_initramfs=${BOOT_INITRAMFS:-/boot/initramfs-linux-rg.img}
module_list=${LINUX_RG_INITRAMFS_MODULES:-"nvme i915"}
console_font=${LINUX_RG_CONSOLE_FONT:-Lat2-Terminus16}
proc_mounts=${LINUX_RG_PROC_MOUNTS:-/proc/mounts}
vconsole_conf=${LINUX_RG_VCONSOLE_CONF:-/etc/vconsole.conf}
boot_check=${LINUX_RG_BOOT_CHECK:-/tmp/rgx1gen11-boot-check}
boot_check_install=${LINUX_RG_BOOT_CHECK_INSTALL:-/usr/local/bin/rgx1gen11-boot-check}
stamp=$(date +%Y%m%d-%H%M%S)

require_root() {
  if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
    echo "error: run as root" >&2
    exit 1
  fi
}

need_file() {
  local path=$1
  if [[ ! -f $path ]]; then
    echo "error: missing file: $path" >&2
    exit 1
  fi
}

backup_file() {
  local path=$1
  if [[ -e $path ]]; then
    local backup="${path}.rg-linux-rg-${stamp}.bak"
    cp -a "$path" "$backup"
    echo "backup: $backup"
  fi
}

package_kver() {
  bsdtar -tf "$kernel_pkg" |
    sed -n 's#^usr/lib/modules/\([^/]*-rg\)/vmlinuz$#\1#p' |
    head -n 1
}

package_has_path() {
  local pkg=$1 path=$2
  bsdtar -tf "$pkg" | rg -qx "$path"
}

validate_package_payload() {
  local path
  for path in \
    usr/bin/rgx1gen11-hibernate-image-size \
    usr/lib/systemd/system/rgx1gen11-hibernate-image-size.service; do
    if ! package_has_path "$kernel_pkg" "$path"; then
      printf 'error: package payload missing: %s\n' "$path" >&2
      exit 1
    fi
  done
}

module_array_literal() {
  local first=1 module out="MODULES=("
  for module in $module_list; do
    if (( first )); then
      out+="$module"
      first=0
    else
      out+=" $module"
    fi
  done
  printf '%s)\n' "$out"
}

line_words() {
  local line=$1
  line=${line#*=}
  line=${line#\(}
  line=${line%\)}
  printf '%s\n' "$line"
}

base_modules_line() {
  grep -E '^[[:space:]]*MODULES=' "$mkinitcpio_base" | tail -n 1 || true
}

base_hooks_line() {
  grep -E '^[[:space:]]*HOOKS=' "$mkinitcpio_base" | tail -n 1 || true
}

hook_line_with_microcode() {
  local line hooks out=() hook inserted=0
  line=$(base_hooks_line)
  hooks=$(line_words "$line")
  for hook in $hooks; do
    if [[ $hook == microcode ]]; then
      continue
    fi
    out+=("$hook")
    if [[ $hook == autodetect ]]; then
      out+=(microcode)
      inserted=1
    fi
  done
  if (( ! inserted )); then
    out=(microcode "${out[@]}")
  fi
  printf 'HOOKS=(%s)\n' "${out[*]}"
}

vconsole_keymap() {
  if [[ -r $vconsole_conf ]]; then
    sed -nE 's/^[[:space:]]*KEYMAP=([^[:space:]#]+).*/\1/p' "$vconsole_conf" | tail -n 1
  fi
}

has_word() {
  local haystack=$1 needle=$2
  [[ " $haystack " == *" $needle "* ]]
}

want_word() {
  local haystack=$1 needle=$2 description=$3
  if ! has_word "$haystack" "$needle"; then
    printf 'error: %s lacks %s: %s\n' "$description" "$needle" "$haystack" >&2
    exit 1
  fi
}

want_prefix_word() {
  local haystack=$1 prefix=$2 description=$3
  local word
  for word in $haystack; do
    if [[ $word == "$prefix"* ]]; then
      return
    fi
  done
  printf 'error: %s lacks %s*: %s\n' "$description" "$prefix" "$haystack" >&2
  exit 1
}

probe_boot_contract() {
  local keymap modules hooks options root_fstype root_source root_line
  modules=$(line_words "$(base_modules_line)")
  hooks=$(line_words "$(base_hooks_line)")
  options=$(stock_options)
  root_line=$(awk '$2 == "/" { print; exit }' "$proc_mounts" 2>/dev/null || true)
  root_source=$(awk '$2 == "/" { print $1; exit }' "$proc_mounts" 2>/dev/null || true)
  root_fstype=$(awk '$2 == "/" { print $3; exit }' "$proc_mounts" 2>/dev/null || true)
  keymap=$(vconsole_keymap)

  want_word "$(module_array_literal | sed -E 's/^MODULES=\((.*)\)$/\1/')" nvme "linux-rg initramfs MODULES"
  want_word "$(module_array_literal | sed -E 's/^MODULES=\((.*)\)$/\1/')" i915 "linux-rg initramfs MODULES"
  want_word "$hooks" block "$mkinitcpio_base HOOKS"
  want_word "$hooks" encrypt "$mkinitcpio_base HOOKS"
  want_word "$hooks" btrfs "$mkinitcpio_base HOOKS"
  want_word "$hooks" resume "$mkinitcpio_base HOOKS"
  want_word "$hooks" keyboard "$mkinitcpio_base HOOKS"
  want_word "$hooks" keymap "$mkinitcpio_base HOOKS"
  want_word "$hooks" consolefont "$mkinitcpio_base HOOKS"
  want_prefix_word "$options" cryptdevice= "$refind_conf options"
  want_word "$options" root=/dev/mapper/luks "$refind_conf options"
  want_word "$options" rootflags=subvol=@ "$refind_conf options"
  want_word "$options" resume=/dev/mapper/luks "$refind_conf options"
  want_prefix_word "$options" resume_offset= "$refind_conf options"
  want_word "$options" i915 "$refind_conf options"
  want_word "$options" pcie_aspm.policy=powersave "$refind_conf options"

  if [[ -n $root_line ]]; then
    if [[ $root_source != /dev/mapper/luks ]]; then
      printf 'error: root source is not /dev/mapper/luks: %s\n' "$root_line" >&2
      exit 1
    fi
    if [[ $root_fstype != btrfs ]]; then
      printf 'error: root filesystem is not btrfs: %s\n' "$root_line" >&2
      exit 1
    fi
  fi

  if [[ $keymap != colemak ]]; then
    printf 'error: %s KEYMAP is not colemak: %s\n' "$vconsole_conf" "${keymap:-missing}" >&2
    exit 1
  fi

  printf 'boot contract: root=%s fstype=%s modules=%s hooks=%s\n' \
    "${root_source:-unknown}" "${root_fstype:-unknown}" \
    "$(module_array_literal)" "$hooks"
  if [[ -n $modules ]]; then
    printf 'base mkinitcpio modules: MODULES=(%s)\n' "$modules"
  fi
  printf 'vconsole keymap: %s\n' "$keymap"
}

write_mkinitcpio_config() {
  local tmp modules_line hooks_line font_line
  tmp=$(mktemp)
  modules_line=$(module_array_literal)
  hooks_line=$(hook_line_with_microcode)
  font_line="FONT=$console_font"
  awk -v modules_line="$modules_line" -v hooks_line="$hooks_line" -v font_line="$font_line" '
    BEGIN {
      replaced_modules = 0
      replaced_hooks = 0
      replaced_font = 0
    }
    /^MODULES=/ {
      print modules_line
      replaced_modules = 1
      next
    }
    /^HOOKS=/ {
      print hooks_line
      replaced_hooks = 1
      next
    }
    /^FONT=/ {
      print font_line
      replaced_font = 1
      next
    }
    { print }
    END {
      if (!replaced_modules) {
        print modules_line
      }
      if (!replaced_hooks) {
        print hooks_line
      }
      if (!replaced_font) {
        print font_line
      }
    }
  ' "$mkinitcpio_base" > "$tmp"

  if [[ ! -e $mkinitcpio_config ]] || ! cmp -s "$tmp" "$mkinitcpio_config"; then
    backup_file "$mkinitcpio_config"
    install -m 0644 "$tmp" "$mkinitcpio_config"
    echo "wrote: $mkinitcpio_config"
  else
    echo "unchanged: $mkinitcpio_config"
  fi
  rm -f "$tmp"
}

write_mkinitcpio_preset() {
  local tmp
  tmp=$(mktemp)
  cat > "$tmp" <<EOF
# mkinitcpio preset file for linux-rg

ALL_config="$mkinitcpio_config"
ALL_kver="$boot_kernel"

PRESETS=('default')

default_image="$boot_initramfs"
EOF

  if [[ ! -e $mkinitcpio_preset ]] || ! cmp -s "$tmp" "$mkinitcpio_preset"; then
    backup_file "$mkinitcpio_preset"
    install -m 0644 "$tmp" "$mkinitcpio_preset"
    echo "wrote: $mkinitcpio_preset"
  else
    echo "unchanged: $mkinitcpio_preset"
  fi
  rm -f "$tmp"
}

stock_options() {
  sed -n '/^menuentry "Arch Linux" {/,/^}/p' "$refind_conf" |
    sed -nE 's/^[[:space:]]*options[[:space:]]+"(.*)"[[:space:]]*$/\1/p' |
    head -n 1
}

write_refind_entry() {
  local options block tmp
  options=$(stock_options)
  if [[ -z $options ]]; then
    echo "error: could not extract stock Arch Linux options from $refind_conf" >&2
    exit 1
  fi

  block=$(mktemp)
  cat > "$block" <<EOF
# linux-rg BEGIN
menuentry "Arch Linux linux-rg" {
    icon     /EFI/refind/icons/os_arch.png
    loader   /vmlinuz-linux-rg
    initrd   /initramfs-linux-rg.img
    options  "$options"
    submenuentry "Boot to terminal" {
        add_options "systemd.unit=multi-user.target"
    }
}
# linux-rg END
EOF

  tmp=$(mktemp)
  if rg -q '^# linux-rg BEGIN$' "$refind_conf"; then
    awk -v block_file="$block" '
      BEGIN {
        while ((getline line < block_file) > 0) {
          block = block line ORS
        }
        close(block_file)
      }
      /^# linux-rg BEGIN$/ {
        if (!done) {
          printf "%s", block
          done = 1
        }
        skip = 1
        next
      }
      /^# linux-rg END$/ {
        skip = 0
        next
      }
      !skip { print }
    ' "$refind_conf" > "$tmp"
  else
    awk -v block_file="$block" '
      BEGIN {
        while ((getline line < block_file) > 0) {
          block = block line ORS
        }
        close(block_file)
      }
      {
        print
        if (!inserted && $0 ~ /^menuentry "Arch Linux" \{[[:space:]]*$/) {
          in_arch = 1
          depth = 1
          next
        }
        if (in_arch) {
          line = $0
          opens = gsub(/\{/, "{", line)
          line = $0
          closes = gsub(/\}/, "}", line)
          depth += opens - closes
          if (depth == 0) {
            print ""
            printf "%s", block
            inserted = 1
            in_arch = 0
          }
        }
      }
      END {
        if (!inserted) {
          print ""
          printf "%s", block
        }
      }
    ' "$refind_conf" > "$tmp"
  fi

  if ! cmp -s "$tmp" "$refind_conf"; then
    backup_file "$refind_conf"
    install -m 0644 "$tmp" "$refind_conf"
    echo "wrote: $refind_conf"
  else
    echo "unchanged: $refind_conf"
  fi
  rm -f "$block" "$tmp"
}

install_boot_check() {
  if command -v rgx1gen11-boot-check >/dev/null 2>&1; then
    echo "boot check provided by package: $(command -v rgx1gen11-boot-check)"
    return
  fi

  if [[ -f $boot_check ]]; then
    install -Dm755 "$boot_check" "$boot_check_install"
    echo "wrote: $boot_check_install"
  else
    echo "skipped: boot check source unavailable at $boot_check"
  fi
}

enable_hibernate_image_size() {
  if ! command -v systemctl >/dev/null 2>&1; then
    echo "error: systemctl unavailable; cannot enable hibernate image-size policy" >&2
    exit 1
  fi
  systemctl enable --now rgx1gen11-hibernate-image-size.service
  if command -v rgx1gen11-hibernate-image-size >/dev/null 2>&1; then
    rgx1gen11-hibernate-image-size status
  fi
}

print_state() {
  echo
  echo "== packages =="
  pacman -Q linux linux-headers linux-firmware mkinitcpio refind linux-rg linux-rg-headers
  echo
  echo "== boot files =="
  ls -lh "$boot_kernel" "$boot_initramfs"
  echo
  echo "== rEFInd linux-rg stanza =="
  rg -n 'linux-rg|vmlinuz-linux-rg|initramfs-linux-rg' "$refind_conf"
  echo
  echo "== disk =="
  df -h / /boot

  echo
  echo "== hibernate image-size policy =="
  systemctl is-enabled rgx1gen11-hibernate-image-size.service
  systemctl is-active rgx1gen11-hibernate-image-size.service || true
  if command -v rgx1gen11-hibernate-image-size >/dev/null 2>&1; then
    rgx1gen11-hibernate-image-size status
  fi

  echo
  echo "== linux-rg boot check =="
  if command -v rgx1gen11-boot-check >/dev/null 2>&1; then
    rgx1gen11-boot-check --installed
  elif [[ -x $boot_check_install ]]; then
    "$boot_check_install" --installed
  elif [[ -f $boot_check ]]; then
    bash "$boot_check" --installed
  else
    echo "skipped: rgx1gen11-boot-check unavailable"
  fi
}

print_plan() {
  local kver options
  kver=$1
  options=$2

  echo "== dry run =="
  echo "kernel package:  $kernel_pkg"
  echo "headers package: $headers_pkg"
  echo "kernel release:  $kver"
  echo "boot kernel:     $boot_kernel"
  echo "boot initramfs:  $boot_initramfs"
  echo "mkinitcpio conf: $mkinitcpio_config"
  echo "mkinitcpio preset: $mkinitcpio_preset"
  echo "boot check:      $boot_check"
  echo "boot check bin:  $boot_check_install"
  echo "initramfs modules: $(module_array_literal)"
  echo "refind config:   $refind_conf"
  echo "refind options:  $options"
  echo
  df -h / /boot
}

main() {
  local dry_run=0
  if [[ ${1:-} == "--dry-run" ]]; then
    dry_run=1
    shift
  fi
  if [[ $# -ne 0 ]]; then
    echo "usage: $0 [--dry-run]" >&2
    exit 2
  fi

  if (( ! dry_run )); then
    require_root
  fi
  need_file "$kernel_pkg"
  need_file "$headers_pkg"
  need_file "$mkinitcpio_base"
  need_file "$refind_conf"
  validate_package_payload

  local kver options
  kver=$(package_kver)
  if [[ -z $kver ]]; then
    echo "error: could not read linux-rg kernel version from $kernel_pkg" >&2
    exit 1
  fi
  options=$(stock_options)
  if [[ -z $options ]]; then
    echo "error: could not extract stock Arch Linux options from $refind_conf" >&2
    exit 1
  fi
  probe_boot_contract
  if (( dry_run )); then
    print_plan "$kver" "$options"
    exit 0
  fi

  echo "== preflight =="
  pacman -Q linux linux-headers linux-firmware mkinitcpio refind
  df -h / /boot

  echo
  echo "== install packages =="
  pacman -U --needed --noconfirm "$kernel_pkg" "$headers_pkg"

  need_file "/usr/lib/modules/$kver/vmlinuz"
  install -m 0644 "/usr/lib/modules/$kver/vmlinuz" "$boot_kernel"
  depmod "$kver"

  echo
  echo "== mkinitcpio =="
  write_mkinitcpio_config
  write_mkinitcpio_preset
  mkinitcpio -p linux-rg

  echo
  echo "== rEFInd =="
  write_refind_entry

  echo
  echo "== boot check helper =="
  install_boot_check

  echo
  echo "== hibernate image-size policy =="
  enable_hibernate_image_size

  print_state
}

main "$@"
