#!/usr/bin/env bash
set -euo pipefail

repo=${1:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}
installer="$repo/scripts/rgx1gen11-install-refind-root"
pkgbuild="$repo/PKGBUILD"
srcinfo="$repo/.SRCINFO"

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  exit 1
}

test -x "$installer" || fail "missing installer: $installer"
test -r "$pkgbuild" || fail "missing package build: $pkgbuild"
test -r "$srcinfo" || fail "missing package metadata: $srcinfo"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

add_initramfs_modules() {
  local root=$1
  local kver=$2
  local rel
  mkdir -p \
    "$root/usr/lib/modules/$kver/kernel/crypto/async_tx" \
    "$root/usr/lib/modules/$kver/kernel/crypto" \
    "$root/usr/lib/modules/$kver/kernel/drivers/md"
  for rel in \
    kernel/crypto/async_tx/async_tx.ko.zst \
    kernel/crypto/async_tx/async_xor.ko.zst \
    kernel/crypto/lz4.ko.zst \
    kernel/crypto/lz4hc.ko.zst \
    kernel/drivers/md/dm-bufio.ko.zst \
    kernel/drivers/md/dm-integrity.ko.zst; do
    touch "$root/usr/lib/modules/$kver/$rel"
  done
}

write_alpha_icon() {
  local path=$1
  cp "$repo/os_linux_rg.png" "$path"
}

write_rgb_icon() {
  local path=$1
  base64 -d >"$path" <<'EOF'

EOF
}

write_white_matte_icon() {
  local path=$1
  magick -size 1x1 xc:'#FFFFFF00' PNG32:"$path"
}

artifact_dir="$tmpdir/artifacts"
pkgroot="$tmpdir/pkgroot"
mkdir -p \
  "$artifact_dir" \
  "$pkgroot/usr/bin" \
  "$pkgroot/usr/lib/modules/9.9.9-rg" \
  "$pkgroot/usr/lib/systemd/system" \
  "$pkgroot/usr/share/libalpm/hooks" \
  "$pkgroot/usr/share/linux-rg/dkms-overlays" \
  "$pkgroot/usr/share/linux-rg/refind"
touch "$pkgroot/usr/lib/modules/9.9.9-rg/vmlinuz"
printf 'linux-rg\n' >"$pkgroot/usr/lib/modules/9.9.9-rg/pkgbase"
touch "$pkgroot/usr/bin/rgx1gen11-boot-check"
touch "$pkgroot/usr/bin/rgx1gen11-dkms-overlay-apply"
touch "$pkgroot/usr/bin/rgx1gen11-hibernate-image-size"
touch "$pkgroot/usr/bin/linux-rg-module-symvers"
touch "$pkgroot/usr/bin/rgx1gen11-live-check"
touch "$pkgroot/usr/lib/systemd/system/rgx1gen11-hibernate-image-size.service"
write_alpha_icon "$pkgroot/usr/share/linux-rg/refind/os_linux_rg.png"
touch "$pkgroot/usr/share/libalpm/hooks/69-linux-rg-dkms-overlays.hook"
touch "$pkgroot/usr/share/linux-rg/dkms-overlays/ddcci-0.4.5-linux-7.0.patch"
touch "$pkgroot/usr/share/linux-rg/dkms-overlays/evdi-1.14.7-linux-7.0.patch"
touch "$pkgroot/usr/share/linux-rg/dkms-overlays/rtl88xxau-r1298-linux-7.0.patch"
add_initramfs_modules "$pkgroot" 9.9.9-rg
bsdtar -cf "$artifact_dir/linux-rg-9.9.9-x86_64.pkg.tar.zst" -C "$pkgroot" usr
touch "$artifact_dir/linux-rg-headers-9.9.9-x86_64.pkg.tar.zst"

bad_pkgroot="$tmpdir/bad-pkgroot"
bad_artifact_dir="$tmpdir/bad-artifacts"
mkdir -p \
  "$bad_artifact_dir" \
  "$bad_pkgroot/usr/bin" \
  "$bad_pkgroot/usr/lib/modules/9.9.8-rg" \
  "$bad_pkgroot/usr/share/libalpm/hooks" \
  "$bad_pkgroot/usr/share/linux-rg/dkms-overlays" \
  "$bad_pkgroot/usr/share/linux-rg/refind"
touch "$bad_pkgroot/usr/lib/modules/9.9.8-rg/vmlinuz"
printf 'linux-rg\n' >"$bad_pkgroot/usr/lib/modules/9.9.8-rg/pkgbase"
touch "$bad_pkgroot/usr/bin/rgx1gen11-boot-check"
touch "$bad_pkgroot/usr/bin/rgx1gen11-dkms-overlay-apply"
touch "$bad_pkgroot/usr/bin/rgx1gen11-hibernate-image-size"
touch "$bad_pkgroot/usr/bin/linux-rg-module-symvers"
touch "$bad_pkgroot/usr/bin/rgx1gen11-live-check"
write_alpha_icon "$bad_pkgroot/usr/share/linux-rg/refind/os_linux_rg.png"
touch "$bad_pkgroot/usr/share/libalpm/hooks/69-linux-rg-dkms-overlays.hook"
touch "$bad_pkgroot/usr/share/linux-rg/dkms-overlays/ddcci-0.4.5-linux-7.0.patch"
touch "$bad_pkgroot/usr/share/linux-rg/dkms-overlays/evdi-1.14.7-linux-7.0.patch"
touch "$bad_pkgroot/usr/share/linux-rg/dkms-overlays/rtl88xxau-r1298-linux-7.0.patch"
add_initramfs_modules "$bad_pkgroot" 9.9.8-rg
bsdtar -cf "$bad_artifact_dir/linux-rg-9.9.8-x86_64.pkg.tar.zst" -C "$bad_pkgroot" usr
touch "$bad_artifact_dir/linux-rg-headers-9.9.8-x86_64.pkg.tar.zst"

bad_payload_pkgroot="$tmpdir/bad-payload-pkgroot"
bad_payload_artifact_dir="$tmpdir/bad-payload-artifacts"
mkdir -p \
  "$bad_payload_artifact_dir" \
  "$bad_payload_pkgroot/usr/bin" \
  "$bad_payload_pkgroot/usr/lib/modules/9.9.7-rg" \
  "$bad_payload_pkgroot/usr/lib/systemd/system" \
  "$bad_payload_pkgroot/usr/share/libalpm/hooks" \
  "$bad_payload_pkgroot/usr/share/linux-rg/dkms-overlays" \
  "$bad_payload_pkgroot/usr/share/linux-rg/refind"
touch "$bad_payload_pkgroot/usr/lib/modules/9.9.7-rg/vmlinuz"
printf 'linux-rg\n' >"$bad_payload_pkgroot/usr/lib/modules/9.9.7-rg/pkgbase"
touch "$bad_payload_pkgroot/usr/bin/rgx1gen11-dkms-overlay-apply"
touch "$bad_payload_pkgroot/usr/bin/rgx1gen11-hibernate-image-size"
touch "$bad_payload_pkgroot/usr/bin/linux-rg-module-symvers"
touch "$bad_payload_pkgroot/usr/bin/rgx1gen11-live-check"
touch "$bad_payload_pkgroot/usr/lib/systemd/system/rgx1gen11-hibernate-image-size.service"
write_alpha_icon "$bad_payload_pkgroot/usr/share/linux-rg/refind/os_linux_rg.png"
touch "$bad_payload_pkgroot/usr/share/libalpm/hooks/69-linux-rg-dkms-overlays.hook"
touch "$bad_payload_pkgroot/usr/share/linux-rg/dkms-overlays/ddcci-0.4.5-linux-7.0.patch"
touch "$bad_payload_pkgroot/usr/share/linux-rg/dkms-overlays/evdi-1.14.7-linux-7.0.patch"
touch "$bad_payload_pkgroot/usr/share/linux-rg/dkms-overlays/rtl88xxau-r1298-linux-7.0.patch"
add_initramfs_modules "$bad_payload_pkgroot" 9.9.7-rg
bsdtar -cf "$bad_payload_artifact_dir/linux-rg-9.9.7-x86_64.pkg.tar.zst" -C "$bad_payload_pkgroot" usr
touch "$bad_payload_artifact_dir/linux-rg-headers-9.9.7-x86_64.pkg.tar.zst"

bad_live_pkgroot="$tmpdir/bad-live-pkgroot"
bad_live_artifact_dir="$tmpdir/bad-live-artifacts"
mkdir -p \
  "$bad_live_artifact_dir" \
  "$bad_live_pkgroot/usr/bin" \
  "$bad_live_pkgroot/usr/lib/modules/9.9.7-rg" \
  "$bad_live_pkgroot/usr/lib/systemd/system" \
  "$bad_live_pkgroot/usr/share/libalpm/hooks" \
  "$bad_live_pkgroot/usr/share/linux-rg/dkms-overlays" \
  "$bad_live_pkgroot/usr/share/linux-rg/refind"
touch "$bad_live_pkgroot/usr/lib/modules/9.9.7-rg/vmlinuz"
printf 'linux-rg\n' >"$bad_live_pkgroot/usr/lib/modules/9.9.7-rg/pkgbase"
touch "$bad_live_pkgroot/usr/bin/rgx1gen11-boot-check"
touch "$bad_live_pkgroot/usr/bin/rgx1gen11-dkms-overlay-apply"
touch "$bad_live_pkgroot/usr/bin/rgx1gen11-hibernate-image-size"
touch "$bad_live_pkgroot/usr/bin/linux-rg-module-symvers"
touch "$bad_live_pkgroot/usr/lib/systemd/system/rgx1gen11-hibernate-image-size.service"
write_alpha_icon "$bad_live_pkgroot/usr/share/linux-rg/refind/os_linux_rg.png"
touch "$bad_live_pkgroot/usr/share/libalpm/hooks/69-linux-rg-dkms-overlays.hook"
touch "$bad_live_pkgroot/usr/share/linux-rg/dkms-overlays/ddcci-0.4.5-linux-7.0.patch"
touch "$bad_live_pkgroot/usr/share/linux-rg/dkms-overlays/evdi-1.14.7-linux-7.0.patch"
touch "$bad_live_pkgroot/usr/share/linux-rg/dkms-overlays/rtl88xxau-r1298-linux-7.0.patch"
add_initramfs_modules "$bad_live_pkgroot" 9.9.7-rg
bsdtar -cf "$bad_live_artifact_dir/linux-rg-9.9.7-x86_64.pkg.tar.zst" -C "$bad_live_pkgroot" usr
touch "$bad_live_artifact_dir/linux-rg-headers-9.9.7-x86_64.pkg.tar.zst"

refind_conf="$tmpdir/refind.conf"
cat >"$refind_conf" <<'EOF'
menuentry "Arch Linux" {
    loader /vmlinuz-linux
    initrd /initramfs-linux.img
    options "cryptdevice=UUID=11111111-2222-3333-4444-555555555555:luks:allow-discards root=/dev/mapper/luks rootflags=subvol=@ rw resume=/dev/mapper/luks resume_offset=12345 i915 pcie_aspm.policy=powersave quiet"
}
EOF

mkinitcpio_base="$tmpdir/mkinitcpio.conf"
cat >"$mkinitcpio_base" <<'EOF'
MODULES=(i915)
BINARIES=()
FILES=()
HOOKS=(base udev plymouth modconf keyboard autodetect kms keymap consolefont block encrypt btrfs resume filesystems fsck)
EOF

proc_mounts="$tmpdir/mounts"
cat >"$proc_mounts" <<'EOF'
/dev/mapper/luks / btrfs rw,relatime,ssd,space_cache=v2,subvolid=256,subvol=/@ 0 0
EOF

vconsole_conf="$tmpdir/vconsole.conf"
cat >"$vconsole_conf" <<'EOF'
KEYMAP=colemak
EOF

out="$tmpdir/dry-run.out"
LINUX_RG_ARTIFACT_DIR="$artifact_dir" \
  LINUX_RG_PROC_MOUNTS="$proc_mounts" \
  LINUX_RG_VCONSOLE_CONF="$vconsole_conf" \
  REFIND_CONF="$refind_conf" \
  MKINITCPIO_BASE="$mkinitcpio_base" \
  "$installer" --dry-run >"$out"

rg -Fq "kernel package:  $artifact_dir/linux-rg-9.9.9-x86_64.pkg.tar.zst" "$out" \
  || fail "dry run should discover linux-rg package from artifact dir"
rg -Fq "headers package: $artifact_dir/linux-rg-headers-9.9.9-x86_64.pkg.tar.zst" "$out" \
  || fail "dry run should discover linux-rg-headers package from artifact dir"
rg -Fq "kernel release:  9.9.9-rg" "$out" \
  || fail "dry run should read kernel release from package"
rg -Fq "boot contract: root=/dev/mapper/luks fstype=btrfs modules=MODULES=(nvme i915)" "$out" \
  || fail "dry run should probe encrypted btrfs boot contract"
rg -Fq "base mkinitcpio modules: MODULES=(i915)" "$out" \
  || fail "dry run should report base early graphics module"
rg -Fq "vconsole keymap: colemak" "$out" \
  || fail "dry run should require the Colemak initramfs keymap"
rg -Fq "initramfs modules: MODULES=(nvme i915)" "$out" \
  || fail "dry run should keep nvme and early i915 in initramfs modules"
rg -Fq "dkms overlay repair: RG_DKMS_JOBS=9 rgx1gen11-dkms-overlay-apply 9.9.9-rg" "$out" \
  || fail "dry run should print DKMS overlay repair"
rg -Fq 'refind icon:' "$out" \
  || fail "dry run should print the rEFInd icon target"
rg -Fq 'refind options:  cryptdevice=UUID=11111111-2222-3333-4444-555555555555:luks:allow-discards root=/dev/mapper/luks rootflags=subvol=@ rw resume=/dev/mapper/luks resume_offset=12345 i915 pcie_aspm.policy=powersave quiet' "$out" \
  || fail "dry run should read encrypted btrfs rEFInd options"
rg -q 'microcode' "$installer" \
  || fail "installer should add the mkinitcpio microcode hook"
if rg -q 'ALL_microcode' "$installer"; then
  fail "installer should not emit deprecated ALL_microcode preset syntax"
fi
rg -q 'console_font=.*Lat2-Terminus16' "$installer" \
  || fail "installer should default the linux-rg console font"
rg -Fq 'font_line="FONT=$console_font"' "$installer" \
  || fail "installer should write the configured console font into linux-rg mkinitcpio"
rg -Fq 'systemctl daemon-reload' "$installer" \
  || fail "installer should reload systemd before enabling packaged units"
rg -Fq 'icon     $refind_icon' "$installer" \
  || fail "installer should write the linux-rg rEFInd icon"
rg -Fq 'usr/share/linux-rg/refind/os_linux_rg.png' "$installer" \
  || fail "installer should require the linux-rg rEFInd icon package payload"
rg -Fq 'usr/bin/linux-rg-module-symvers' "$installer" \
  || fail "installer should require the linux-rg module symvers helper"

bad_out="$tmpdir/bad-dry-run.out"
if LINUX_RG_ARTIFACT_DIR="$bad_artifact_dir" \
  LINUX_RG_PROC_MOUNTS="$proc_mounts" \
  LINUX_RG_VCONSOLE_CONF="$vconsole_conf" \
  REFIND_CONF="$refind_conf" \
  MKINITCPIO_BASE="$mkinitcpio_base" \
  "$installer" --dry-run >"$bad_out" 2>&1; then
  fail "dry run should reject a stale package without the hibernate image-size unit"
fi
rg -Fq 'package payload missing: usr/lib/systemd/system/rgx1gen11-hibernate-image-size.service' "$bad_out" \
  || fail "stale package rejection should name the missing hibernate image-size unit"

bad_live_out="$tmpdir/bad-live-dry-run.out"
if LINUX_RG_ARTIFACT_DIR="$bad_live_artifact_dir" \
  LINUX_RG_PROC_MOUNTS="$proc_mounts" \
  LINUX_RG_VCONSOLE_CONF="$vconsole_conf" \
  REFIND_CONF="$refind_conf" \
  MKINITCPIO_BASE="$mkinitcpio_base" \
  "$installer" --dry-run >"$bad_live_out" 2>&1; then
  fail "dry run should reject a stale package without live-check"
fi
rg -Fq 'package payload missing: usr/bin/rgx1gen11-live-check' "$bad_live_out" \
  || fail "stale package rejection should name the missing live-check helper"

bad_payload_out="$tmpdir/bad-payload-dry-run.out"
if LINUX_RG_ARTIFACT_DIR="$bad_payload_artifact_dir" \
  LINUX_RG_PROC_MOUNTS="$proc_mounts" \
  LINUX_RG_VCONSOLE_CONF="$vconsole_conf" \
  REFIND_CONF="$refind_conf" \
  MKINITCPIO_BASE="$mkinitcpio_base" \
  "$installer" --dry-run >"$bad_payload_out" 2>&1; then
  fail "dry run should reject a stale package without boot-check"
fi
rg -Fq 'package payload missing: usr/bin/rgx1gen11-boot-check' "$bad_payload_out" \
  || fail "stale package rejection should name the missing boot-check helper"

bad_icon_pkgroot="$tmpdir/bad-icon-pkgroot"
bad_icon_artifact_dir="$tmpdir/bad-icon-artifacts"
mkdir -p \
  "$bad_icon_artifact_dir" \
  "$bad_icon_pkgroot/usr/bin" \
  "$bad_icon_pkgroot/usr/lib/modules/9.9.6-rg" \
  "$bad_icon_pkgroot/usr/lib/systemd/system" \
  "$bad_icon_pkgroot/usr/share/libalpm/hooks" \
  "$bad_icon_pkgroot/usr/share/linux-rg/dkms-overlays" \
  "$bad_icon_pkgroot/usr/share/linux-rg/refind"
touch "$bad_icon_pkgroot/usr/lib/modules/9.9.6-rg/vmlinuz"
printf 'linux-rg\n' >"$bad_icon_pkgroot/usr/lib/modules/9.9.6-rg/pkgbase"
touch "$bad_icon_pkgroot/usr/bin/rgx1gen11-boot-check"
touch "$bad_icon_pkgroot/usr/bin/rgx1gen11-dkms-overlay-apply"
touch "$bad_icon_pkgroot/usr/bin/rgx1gen11-hibernate-image-size"
touch "$bad_icon_pkgroot/usr/bin/linux-rg-module-symvers"
touch "$bad_icon_pkgroot/usr/bin/rgx1gen11-live-check"
touch "$bad_icon_pkgroot/usr/lib/systemd/system/rgx1gen11-hibernate-image-size.service"
write_rgb_icon "$bad_icon_pkgroot/usr/share/linux-rg/refind/os_linux_rg.png"
touch "$bad_icon_pkgroot/usr/share/libalpm/hooks/69-linux-rg-dkms-overlays.hook"
touch "$bad_icon_pkgroot/usr/share/linux-rg/dkms-overlays/ddcci-0.4.5-linux-7.0.patch"
touch "$bad_icon_pkgroot/usr/share/linux-rg/dkms-overlays/evdi-1.14.7-linux-7.0.patch"
touch "$bad_icon_pkgroot/usr/share/linux-rg/dkms-overlays/rtl88xxau-r1298-linux-7.0.patch"
add_initramfs_modules "$bad_icon_pkgroot" 9.9.6-rg
bsdtar -cf "$bad_icon_artifact_dir/linux-rg-9.9.6-x86_64.pkg.tar.zst" -C "$bad_icon_pkgroot" usr
touch "$bad_icon_artifact_dir/linux-rg-headers-9.9.6-x86_64.pkg.tar.zst"
bad_icon_out="$tmpdir/bad-icon-dry-run.out"
if LINUX_RG_ARTIFACT_DIR="$bad_icon_artifact_dir" \
  LINUX_RG_PROC_MOUNTS="$proc_mounts" \
  LINUX_RG_VCONSOLE_CONF="$vconsole_conf" \
  REFIND_CONF="$refind_conf" \
  MKINITCPIO_BASE="$mkinitcpio_base" \
  "$installer" --dry-run >"$bad_icon_out" 2>&1; then
  fail "dry run should reject package rEFInd icon without alpha"
fi
rg -Fq 'package rEFInd icon lacks PNG alpha channel: usr/share/linux-rg/refind/os_linux_rg.png' "$bad_icon_out" \
  || fail "RGB icon rejection should name the rEFInd icon payload"

if command -v magick >/dev/null 2>&1; then
  bad_matte_artifact_dir="$tmpdir/bad-matte-artifacts"
  mkdir -p "$bad_matte_artifact_dir"
  write_white_matte_icon "$bad_icon_pkgroot/usr/share/linux-rg/refind/os_linux_rg.png"
  bsdtar -cf "$bad_matte_artifact_dir/linux-rg-9.9.6-x86_64.pkg.tar.zst" -C "$bad_icon_pkgroot" usr
  touch "$bad_matte_artifact_dir/linux-rg-headers-9.9.6-x86_64.pkg.tar.zst"
  bad_matte_out="$tmpdir/bad-matte-dry-run.out"
  if LINUX_RG_ARTIFACT_DIR="$bad_matte_artifact_dir" \
    LINUX_RG_PROC_MOUNTS="$proc_mounts" \
    LINUX_RG_VCONSOLE_CONF="$vconsole_conf" \
    REFIND_CONF="$refind_conf" \
    MKINITCPIO_BASE="$mkinitcpio_base" \
    "$installer" --dry-run >"$bad_matte_out" 2>&1; then
    fail "dry run should reject a package rEFInd icon with a white transparent matte"
  fi
  rg -Fq 'package rEFInd icon transparent matte is white:' "$bad_matte_out" \
    || fail "white-matte icon rejection should name the rEFInd icon matte"
fi

rg -q "'scx-tools:.*scx_loader" "$pkgbuild" \
  || fail "PKGBUILD should name the Arch package that provides scx_loader"
if rg -q 'scx_loader: ASA router expert scheduler switching' "$pkgbuild" "$srcinfo"; then
  fail "package metadata should not name scx_loader as an Arch package"
fi
rg -q 'optdepends = scx-tools: ASA router expert scheduler switching' "$srcinfo" \
  || fail ".SRCINFO should publish the scx-tools optional dependency"

printf 'ok\n'
