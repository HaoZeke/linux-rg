CONFIG_VFAT_FS=m
# overlayfs in-tree, built against this exact kernel. localmodconfig prunes the
# base config.x86_64 CONFIG_OVERLAY_FS=m because overlay is absent from
# rgx1gen11.lsmod, so re-pin it here after the prune. An in-tree overlay.ko
# matches the running populate_error_injection_list() section layout; a
# mismatched out-of-tree _error_injection_whitelist section NULL-derefs the
# tracepoint module notifier on load.
CONFIG_OVERLAY_FS=m
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
# CONFIG_OVERLAY_FS_REDIRECT_ALWAYS_FOLLOW is not set
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_OVERLAY_FS_XINO_AUTO=y
CONFIG_OVERLAY_FS_METACOPY=y
# CONFIG_OVERLAY_FS_DEBUG is not set
# USB mass storage, pruned by localmodconfig because no USB stick was attached
# when rgx1gen11.lsmod was captured. SCSI and BLK_DEV_SD are already =y, so
# without this the kernel enumerates a USB stick but binds no driver and creates
# no /dev/sdX (cannot flash an ISO or mount any USB drive). UAS covers the
# faster usb-attached-scsi path.
CONFIG_USB_STORAGE=m
CONFIG_USB_UAS=m
# More localmodconfig casualties: modules absent from rgx1gen11.lsmod at capture
# time but needed on a docker-running daily driver. All ship in stock Arch as =m.
# loopback + network block device: mount ISO/img files, qemu-nbd qcow2 images.
CONFIG_BLK_DEV_LOOP=m
CONFIG_BLK_DEV_NBD=m
# container/VM networking: docker bridges and veth pairs, fast KVM/QEMU net.
# KVM and TUN survive the prune, but the bridge/veth/macvlan/vhost set did not.
CONFIG_BRIDGE=m
CONFIG_VETH=m
CONFIG_MACVLAN=m
CONFIG_VHOST_NET=m
# USB ethernet (USB-C dock / travel dongle); the whole USB_NET_DRIVERS family was
# pruned because none was attached when the lsmod snapshot was taken.
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_USBNET=m
CONFIG_USB_NET_CDCETHER=m
CONFIG_USB_NET_AX88179_178A=m
CONFIG_USB_RTL8152=m
# removable-media filesystems for sticks formatted on Windows/macOS.
CONFIG_EXFAT_FS=m
CONFIG_NTFS3_FS=m
# NFS client for mounting shares.
CONFIG_NFS_FS=m
# USB-serial chip backends (USB_SERIAL core is =y; the chip drivers were pruned).
CONFIG_USB_SERIAL_FTDI_SIO=m
CONFIG_USB_SERIAL_CP210X=m
CONFIG_USB_SERIAL_CH341=m
CONFIG_USB4=m
CONFIG_THUNDERBOLT=m
CONFIG_TYPEC=m
CONFIG_TYPEC_TCPM=m
CONFIG_TYPEC_UCSI=m
CONFIG_TYPEC_MUX_INTEL_PMC=m
CONFIG_TYPEC_DP_ALTMODE=m
CONFIG_TYPEC_TBT_ALTMODE=m
CONFIG_UCSI_ACPI=m
CONFIG_HID_MULTITOUCH=m
CONFIG_I2C_HID_ACPI=m
CONFIG_PINCTRL_TIGERLAKE=m
CONFIG_MEDIA_SUPPORT=m
CONFIG_MEDIA_SUPPORT_FILTER=y
CONFIG_MEDIA_CAMERA_SUPPORT=y
# CONFIG_MEDIA_ANALOG_TV_SUPPORT is not set
# CONFIG_MEDIA_DIGITAL_TV_SUPPORT is not set
# CONFIG_MEDIA_RADIO_SUPPORT is not set
# CONFIG_MEDIA_SDR_SUPPORT is not set
# CONFIG_MEDIA_TEST_SUPPORT is not set
CONFIG_VIDEO_DEV=m
CONFIG_MEDIA_CONTROLLER=y
CONFIG_USB_VIDEO_CLASS=m
CONFIG_V4L2_LOOPBACK=m

# rgx1gen11 compile-time pruning. Keep laptop, dock, and common USB-network
# paths; drop device-controller, non-Intel wireless, and non-Intel GPU families
# absent from 21HM002GUS.
# CONFIG_DRM_AMDGPU is not set
# CONFIG_DRM_NOUVEAU is not set
# CONFIG_DRM_RADEON is not set
# CONFIG_DRM_VKMS is not set
# CONFIG_USB_GADGET is not set
# CONFIG_WLAN_VENDOR_ADMTEK is not set
# CONFIG_WLAN_VENDOR_ATH is not set
# CONFIG_WLAN_VENDOR_ATMEL is not set
# CONFIG_WLAN_VENDOR_BROADCOM is not set
# CONFIG_WLAN_VENDOR_INTERSIL is not set
# CONFIG_WLAN_VENDOR_MARVELL is not set
# CONFIG_WLAN_VENDOR_MEDIATEK is not set
# CONFIG_WLAN_VENDOR_MICROCHIP is not set
# CONFIG_WLAN_VENDOR_PURELIFI is not set
# CONFIG_WLAN_VENDOR_RALINK is not set
# CONFIG_WLAN_VENDOR_REALTEK is not set
# CONFIG_WLAN_VENDOR_RSI is not set
# CONFIG_WLAN_VENDOR_SILABS is not set
# CONFIG_WLAN_VENDOR_ST is not set
# CONFIG_WLAN_VENDOR_TI is not set
# CONFIG_WLAN_VENDOR_ZYDAS is not set
# CONFIG_WLAN_VENDOR_QUANTENNA is not set

# Intel AVS ASoC: no machine boards on 21HM002GUS (all AVS_MACH_* off), so it
# can never bind a card, yet it loads, competes in DSP arbitration for the
# cAVS device, and its probe produced a DIE-tainting oops and the 2026-07-10
# soft lockup during driver rebind. SOF drives the device (dsp_driver=3 pin).
# CONFIG_SND_SOC_INTEL_AVS is not set
