#!/usr/bin/env bash
set -euo pipefail

config_path=${RGAM5TERRA_CONFIG:-rgam5terra.config}
sys_root=${RGAM5TERRA_SYS_ROOT:-/sys}
cmdline_path=${RGAM5TERRA_CMDLINE:-/proc/cmdline}
nvme_name=nvme0
block_name=nvme0n1
expected_model="WD_BLACK SN850X"
expected_scheduler=bfq
feature_device=/dev/nvme0
live=0
require_apst=0
allow_apst_disabled=0

usage() {
  cat <<'USAGE'
usage: rgam5terra-nvme-check [options]

Validate the rgam5terra WD SN850X NVMe kernel and live policy contract.

Options:
  --config PATH             Kconfig file to inspect (default: rgam5terra.config)
  --sys-root PATH           sysfs root to inspect (default: /sys)
  --cmdline PATH            kernel command line path (default: /proc/cmdline)
  --nvme NAME               NVMe controller sysfs name (default: nvme0)
  --block NAME              Block device sysfs name (default: nvme0n1)
  --model TEXT              Expected model prefix (default: WD_BLACK SN850X)
  --scheduler NAME          Expected active queue scheduler (default: bfq)
  --feature-device PATH     Device for nvme-cli APST feature reads (default: /dev/nvme0)
  --require-apst            Require nvme-cli APST feature 0x0c to report enabled
  --allow-apst-disabled     Accept nvme_core.default_ps_max_latency_us=0 fallback
  --live                    Check live sysfs and nvme-cli state
  -h, --help                Show this help
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --config)
      config_path=$2
      shift 2
      ;;
    --sys-root)
      sys_root=$2
      shift 2
      ;;
    --cmdline)
      cmdline_path=$2
      shift 2
      ;;
    --nvme)
      nvme_name=$2
      shift 2
      ;;
    --block)
      block_name=$2
      shift 2
      ;;
    --model)
      expected_model=$2
      shift 2
      ;;
    --scheduler)
      expected_scheduler=$2
      shift 2
      ;;
    --feature-device)
      feature_device=$2
      shift 2
      ;;
    --require-apst)
      require_apst=1
      shift
      ;;
    --allow-apst-disabled)
      allow_apst_disabled=1
      shift
      ;;
    --live)
      live=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

failures=0

pass() {
  printf 'ok: %s\n' "$1"
}

fail() {
  printf 'fail: %s\n' "$1" >&2
  failures=$((failures + 1))
}

trim() {
  local value=$1
  value=${value#"${value%%[![:space:]]*}"}
  value=${value%"${value##*[![:space:]]}"}
  printf '%s' "$value"
}

want_config() {
  local symbol=$1
  local want=$2
  local got

  if [[ ! -r $config_path ]]; then
    fail "config is not readable: $config_path"
    return
  fi

  got=$(grep -E "^(# )?${symbol}(=| is not set)" "$config_path" || true)
  if [[ $got == "$want" ]]; then
    pass "$want"
  elif [[ -n $got ]]; then
    fail "$symbol is '$got', expected '$want'"
  else
    fail "$symbol is missing, expected '$want'"
  fi
}

want_model_prefix() {
  local path="$sys_root/class/nvme/$nvme_name/model"
  local got

  [[ $live -eq 1 ]] || return 0
  if [[ ! -r $path ]]; then
    fail "NVMe model is not readable: $path"
    return
  fi

  got=$(trim "$(<"$path")")
  if [[ $got == "$expected_model"* ]]; then
    pass "$nvme_name model $got"
  else
    fail "$nvme_name model is '$got', expected prefix '$expected_model'"
  fi
}

want_scheduler() {
  local path="$sys_root/block/$block_name/queue/scheduler"
  local got

  [[ $live -eq 1 ]] || return 0
  if [[ ! -r $path ]]; then
    fail "queue scheduler is not readable: $path"
    return
  fi

  got=$(<"$path")
  if [[ " $got " == *" [$expected_scheduler] "* ]]; then
    pass "$block_name scheduler $expected_scheduler"
  else
    fail "$block_name scheduler is '$got', expected [$expected_scheduler]"
  fi
}

want_cmdline_policy() {
  local cmdline

  [[ $live -eq 1 ]] || return 0
  if [[ ! -r $cmdline_path ]]; then
    fail "$cmdline_path is not readable"
    return
  fi

  cmdline=$(<"$cmdline_path")
  if [[ $allow_apst_disabled -eq 1 ]]; then
    if [[ " $cmdline " == *" nvme_core.default_ps_max_latency_us=0 "* ]]; then
      pass "cmdline documents APST disabled fallback"
    else
      fail "APST fallback allowed but cmdline lacks nvme_core.default_ps_max_latency_us=0"
    fi
  elif [[ " $cmdline " == *" nvme_core.default_ps_max_latency_us=0 "* ]]; then
    fail "APST disabled on cmdline without --allow-apst-disabled"
  else
    pass "cmdline leaves APST probe enabled"
  fi
}

want_apst_feature() {
  local output

  [[ $live -eq 1 && $require_apst -eq 1 ]] || return 0
  if ! command -v nvme >/dev/null 2>&1; then
    fail "nvme-cli unavailable for APST feature check"
    return
  fi
  if output=$(nvme get-feature "$feature_device" -f 0x0c 2>&1); then
    if grep -Eq 'APSTE\): Enabled|Current value:0x0*1' <<<"$output"; then
      pass "$feature_device APST feature enabled"
    else
      fail "$feature_device APST feature output does not report enabled"
    fi
  else
    fail "nvme get-feature failed: $output"
  fi
}

want_config CONFIG_BLK_DEV_NVME 'CONFIG_BLK_DEV_NVME=m'
want_config CONFIG_NVME_CORE 'CONFIG_NVME_CORE=m'
want_config CONFIG_NVME_HWMON 'CONFIG_NVME_HWMON=y'
want_config CONFIG_NVME_MULTIPATH 'CONFIG_NVME_MULTIPATH=y'
want_config CONFIG_IOSCHED_BFQ 'CONFIG_IOSCHED_BFQ=y'
want_config CONFIG_MQ_IOSCHED_ADIOS 'CONFIG_MQ_IOSCHED_ADIOS=m'

want_model_prefix
want_scheduler
want_cmdline_policy
want_apst_feature

if [[ $failures -gt 0 ]]; then
  exit 1
fi
