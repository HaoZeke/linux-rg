#!/usr/bin/env bash
set -euo pipefail

repo=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
checker="$repo/rgx1gen11-s0ix-preflight"

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  exit 1
}

test -x "$checker" || fail "missing executable S0ix preflight"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

mkdir -p "$tmpdir/sys/power" "$tmpdir/sys/kernel/debug/pmc_core" "$tmpdir/bin" "$tmpdir/tool"
printf 'freeze mem disk\n' >"$tmpdir/sys/power/state"
printf '[s2idle] deep\n' >"$tmpdir/sys/power/mem_sleep"
printf '123456\n' >"$tmpdir/sys/kernel/debug/pmc_core/slp_s0_residency_usec"
printf '#!/usr/bin/env bash\nexit 0\n' >"$tmpdir/tool/s0ix-selftest-tool.sh"
chmod +x "$tmpdir/tool/s0ix-selftest-tool.sh"

for tool in gawk xxd turbostat powertop acpidump; do
  printf '#!/usr/bin/env bash\nexit 0\n' >"$tmpdir/bin/$tool"
  chmod +x "$tmpdir/bin/$tool"
done

output=$(
  RGX1GEN11_SYS_ROOT="$tmpdir/sys" \
    S0IX_TOOL="$tmpdir/tool/s0ix-selftest-tool.sh" \
    PATH="$tmpdir/bin:$PATH" \
    "$checker"
)

printf '%s\n' "$output" | rg -q 'ok: mem_sleep exposes s2idle' \
  || fail "preflight should accept s2idle mem_sleep"
printf '%s\n' "$output" | rg -q 'ok: pmc_core SLP_S0 residency counter readable' \
  || fail "preflight should find PMC residency counter"
printf '%s\n' "$output" | rg -q 'sudo bash .*s0ix-selftest-tool.sh -s' \
  || fail "preflight should print suspend selftest command"
printf '%s\n' "$output" | rg -q 'sudo bash .*s0ix-selftest-tool.sh -r on' \
  || fail "preflight should print runtime PC10 screen-on command"
printf '%s\n' "$output" | rg -q 'sudo bash .*s0ix-selftest-tool.sh -r off' \
  || fail "preflight should print runtime PC10 screen-off command"

mkdir -p "$tmpdir/cache/rg-kernel/S0ixSelftestTool"
cp "$tmpdir/tool/s0ix-selftest-tool.sh" "$tmpdir/cache/rg-kernel/S0ixSelftestTool/s0ix-selftest-tool.sh"
output=$(
  env -u S0IX_TOOL \
    XDG_CACHE_HOME="$tmpdir/cache" \
    HOME="$tmpdir/home" \
    RGX1GEN11_SYS_ROOT="$tmpdir/sys" \
    PATH="$tmpdir/bin:$PATH" \
    "$checker"
)
printf '%s\n' "$output" | rg -q 'ok: S0ixSelftestTool executable .*/rg-kernel/S0ixSelftestTool/s0ix-selftest-tool.sh' \
  || fail "preflight should discover the managed S0ixSelftestTool checkout"

chmod 000 "$tmpdir/sys/kernel/debug/pmc_core/slp_s0_residency_usec"
if RGX1GEN11_SYS_ROOT="$tmpdir/sys" \
  S0IX_TOOL="$tmpdir/tool/s0ix-selftest-tool.sh" \
  PATH="$tmpdir/bin:$PATH" \
  "$checker" >/tmp/rgx1gen11-s0ix-preflight.pmc 2>&1; then
  fail "preflight should fail when the PMC counter exists but is not readable"
fi
chmod 600 "$tmpdir/sys/kernel/debug/pmc_core/slp_s0_residency_usec"
rg -q 'fail: pmc_core SLP_S0 residency counter present but not readable' /tmp/rgx1gen11-s0ix-preflight.pmc \
  || fail "preflight should distinguish root-only PMC debugfs access"

printf 'deep\n' >"$tmpdir/sys/power/mem_sleep"
if RGX1GEN11_SYS_ROOT="$tmpdir/sys" \
  S0IX_TOOL="$tmpdir/tool/s0ix-selftest-tool.sh" \
  PATH="$tmpdir/bin:$PATH" \
  "$checker" >/tmp/rgx1gen11-s0ix-preflight.bad 2>&1; then
  fail "preflight should fail when s2idle is unavailable"
fi
rg -q 'fail: mem_sleep lacks s2idle' /tmp/rgx1gen11-s0ix-preflight.bad \
  || fail "preflight failure should name missing s2idle"

printf 'ok\n'
